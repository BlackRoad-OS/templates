# BlackRoad Agent Jobs Worker - Environment Variables
# Copy this file to .env and fill in the values

# ========================================
# Cloudflare Configuration
# ========================================

# Cloudflare Account ID (find in dashboard)
CLOUDFLARE_ACCOUNT_ID=your_account_id

# Cloudflare API Token (create at https://dash.cloudflare.com/profile/api-tokens)
# Required permissions: Workers Scripts:Edit, D1:Edit, R2:Edit, Queues:Edit
CLOUDFLARE_API_TOKEN=your_api_token

# ========================================
# Worker Secrets (set via wrangler secret put)
# ========================================

# GitHub Personal Access Token for API access
# Required scopes: repo (for private repos), read:org
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Webhook secret for GitHub webhook signature verification
WEBHOOK_SECRET=your_webhook_secret_here

# Anthropic API Key for Claude agent tasks
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ========================================
# Optional Configuration
# ========================================

# Admin token for protected endpoints
ADMIN_TOKEN=your_admin_token

# Slack webhook for notifications (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# PagerDuty integration key (optional)
PAGERDUTY_INTEGRATION_KEY=your_key

# ========================================
# Local Development
# ========================================

# Set to true for local development
LOCAL_DEV=false

# Local proxy URL (if using)
# LOCAL_PROXY=http://localhost:8787
